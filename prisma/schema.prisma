generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Charity {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  target      Float
  current     Float    @default(0)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Donation {
  id        Int      @id @default(autoincrement())
  amount    Float
  status    String   @default("pending")
  type      String
  userId    Int
  charityId Int
  createdAt DateTime @default(now())
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  image     String?
  charityId Int
  createdAt DateTime @default(now())
}
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  postId    Int
  userId    Int
  userName  String
  createdAt DateTime @default(now())
}